# 복사해서 .env 로 쓰고 값 채우기 (.env 는 커밋 금지 — .gitignore 확인)

# PokemonPriceTracker — 무료 가입 후 API 키 발급
# https://www.pokemonpricetracker.com  → 가입 → API 키
PPT_API_KEY=
# 선택: 베이스 URL 오버라이드 (키 발급 후 실제 엔드포인트로 확정)
# PPT_BASE_URL=https://www.pokemonpricetracker.com/api/v2

# Phase 4 (발행) — Buffer(→ TikTok/Shorts). 무료 가입 후 토큰/프로필ID 발급.
# publish.mjs 는 토큰+--confirm 둘 다 있을 때만 실제 발행(기본 dry-run).
BUFFER_ACCESS_TOKEN=
# 발행 대상 프로필 ID(쉼표 구분)
BUFFER_PROFILE_IDS=
